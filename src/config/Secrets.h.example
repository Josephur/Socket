#pragma once

// Copy this file to Secrets.h (gitignored) and fill in real values.
// Socket.ino uses these only as a first-boot fallback: if WiFiManager finds
// no credentials already stored in NVS, it seeds them from here once. There
// is no captive-portal/setup-flow for entering WiFi credentials on-device
// yet (see the plan's "Deferred / roadmap") -- this is the stopgap until
// one exists.

#define SOCKET_WIFI_SSID "your-shop-wifi-ssid"
#define SOCKET_WIFI_PASSWORD "your-shop-wifi-password"

// Base URL of the Stack-Tech PHP provisioning endpoint, e.g.
// "https://stack-tech.local/api/provision". The device appends
// "?device_id=<chip id>" itself -- see ProvisioningClient.h.
#define SOCKET_PROVISIONING_URL "https://stack-tech.local/api/provision"
